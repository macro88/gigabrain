---
import Icon from './GuideIcon.astro';

interface Props {
	title: string;
	icon?: string;
	eyebrow: string;
	href: string;
	linkText: string;
}

const { title, icon, eyebrow, href, linkText } = Astro.props;
---

<a class="gb-audience-card" href={href}>
	<p class="gb-audience-card__eyebrow">{eyebrow}</p>
	<div class="gb-audience-card__head">
		{icon && (
			<span class="gb-audience-card__icon" aria-hidden="true">
				<Icon name={icon as any} />
			</span>
		)}
		<h3>{title}</h3>
	</div>
	<div class="gb-audience-card__body">
		<slot />
	</div>
	<span class="gb-audience-card__link">
		<span>{linkText}</span>
		<Icon name="right-arrow" size="1rem" />
	</span>
</a>

<style>
	.gb-audience-card {
		display: grid;
		gap: 1rem;
		padding: 1.6rem;
		border-radius: 1.1rem;
		border: 1px solid rgba(165, 154, 122, 0.18);
		background: var(--q-stone, #2A2A2A);
		box-shadow: 0 18px 32px -28px rgba(0, 0, 0, 0.38);
		text-decoration: none;
		color: inherit;
		transition: transform 120ms ease, box-shadow 200ms ease, border-color 200ms ease;
	}

	:global(:root[data-theme="light"]) .gb-audience-card {
		background: var(--gb-surface-low, #EDEAE4);
		border-color: rgba(165, 154, 122, 0.25);
		box-shadow: 0 18px 32px -28px rgba(0, 0, 0, 0.08);
	}

	.gb-audience-card:hover {
		transform: translateY(-2px);
		border-color: rgba(165, 154, 122, 0.40);
		box-shadow: 0 24px 36px -28px rgba(0, 0, 0, 0.32);
	}

	.gb-audience-card__eyebrow {
		margin: 0;
		color: var(--q-bronze, #A59A7A);
		font-size: 0.74rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.gb-audience-card__head {
		display: flex;
		align-items: center;
		gap: 0.85rem;
	}

	.gb-audience-card__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 0.8rem;
		background: rgba(165, 154, 122, 0.15);
		color: var(--q-bronze, #A59A7A);
	}

	.gb-audience-card h3 {
		margin: 0;
		color: var(--gb-on-surface);
		font-size: 1.3rem;
		font-weight: 700;
		letter-spacing: -0.025em;
	}

	.gb-audience-card__body {
		color: var(--sl-color-gray-3);
		font-size: 0.98rem;
		line-height: 1.65;
	}

	.gb-audience-card__body :global(p) {
		margin: 0;
	}

	.gb-audience-card__link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--q-bronze, #A59A7A);
		font-size: 0.92rem;
		font-weight: 700;
	}

	.gb-audience-card:hover .gb-audience-card__link {
		gap: 0.7rem;
	}
</style>
