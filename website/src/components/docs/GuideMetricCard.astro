---
interface Props {
	value: string;
	label: string;
	note?: string;
}

const { value, label, note } = Astro.props;
---

<div class="gb-guide-metric">
	<div class="gb-guide-metric__value">{value}</div>
	<div class="gb-guide-metric__label">{label}</div>
	{note && <p class="gb-guide-metric__note">{note}</p>}
</div>

<style>
	.gb-guide-metric {
		display: grid;
		gap: 0.35rem;
		padding: 1.2rem;
		border-radius: 1rem;
		border: 1px solid rgba(165, 154, 122, 0.18);
		background: var(--q-stone, #2A2A2A);
	}

	:global(:root[data-theme="light"]) .gb-guide-metric {
		background: var(--gb-surface-low, #EDEAE4);
		border-color: rgba(165, 154, 122, 0.25);
	}

	.gb-guide-metric__value {
		color: var(--q-bronze, #A59A7A);
		font-size: clamp(1.5rem, 2vw, 2rem);
		font-weight: 800;
		letter-spacing: -0.04em;
	}

	.gb-guide-metric__label {
		color: var(--gb-on-surface);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.gb-guide-metric__note {
		margin: 0;
		color: var(--sl-color-gray-3);
		font-size: 0.92rem;
		line-height: 1.55;
	}
</style>
